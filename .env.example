# Database Configuration
# For local development, SQLite is used by default
# For production, use PostgreSQL
DATABASE_URL=sqlite:///./data/dev.db
# DATABASE_URL=postgresql://jeevn:jeevn@localhost:5432/ashi

# Sentinel-2 Credentials (optional)
# If not provided, the system will fall back to stub ingest
SENTINEL_USER=your_copernicus_username
SENTINEL_PASS=your_copernicus_password

# Download Sentinel-2 Products (optional)
# Set to "1" to download actual products, "0" to download metadata only
DOWNLOAD_PRODUCTS=0

# S3/MinIO Configuration (optional)
# For storing artifacts in object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000

# MLflow Configuration (optional)
MLFLOW_TRACKING_URI=http://localhost:5000

# Python Logging
PYTHONUNBUFFERED=1
